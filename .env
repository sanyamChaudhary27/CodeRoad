# Application Settings
DEBUG=true
HOST=0.0.0.0
PORT=8000
APP_NAME=Code Road

# Database (Using SQLite for local development)
DATABASE_URL=sqlite:///./coderoad.db

# Redis (Optional for local testing)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=dev-secret-key-change-in-production-12345678901234567890

# CORS Origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000","http://127.0.0.1:8000"]

# Match Settings
MATCHMAKING_TIMEOUT_SECONDS=60
MATCH_DURATION_MIN_SECONDS=30
MATCH_DURATION_MAX_SECONDS=120
ELO_MATCHING_RANGE=200
ELO_K_FACTOR=32
INITIAL_ELO_RATING=1200

# Code Execution
CODE_EXECUTION_TIMEOUT_SECONDS=5
CODE_MEMORY_LIMIT_MB=256
CODE_CPU_LIMIT=1

# ML Service URLs (Placeholder - will be provided by Gajendra)
CHALLENGE_SERVICE_URL=http://localhost:8001
JUDGE_SERVICE_URL=http://localhost:8002
INTEGRITY_SERVICE_URL=http://localhost:8003

# WebSocket Settings
WEBSOCKET_PING_INTERVAL=20
WEBSOCKET_PING_TIMEOUT=40

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD_SECONDS=60

# Logging
LOG_LEVEL=INFO