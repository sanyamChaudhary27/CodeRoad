# Local backend configuration. Copy to backend/.env; never commit backend/.env.
DEBUG=true
HOST=0.0.0.0
PORT=8000
DATABASE_URL=sqlite:///./coderoad.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=replace-with-a-long-random-value

# Adversarial Test Arena
# The OpenAI key is optional: without it, the typed deterministic fallback runs.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=20
OPENAI_CACHE_MAX_ENTRIES=128
ATTACK_ROUND_MAX_CANDIDATES=12

# Required for every real player-code execution. Host Judge0 separately.
JUDGE0_API_URL=https://ce.judge0.com
JUDGE0_AUTH_TOKEN=
JUDGE0_AUTH_HEADER=X-Auth-Token
JUDGE0_PYTHON_LANGUAGE_ID=71

# Existing challenge generation service, if used.
GROQ_API_KEY=
